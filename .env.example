# === VEX Consulting — variables de entorno ===

ENV=development
SECRET_KEY=cambiar-esta-clave-larga-y-aleatoria

# Postgres (Render: pegar la Internal Database URL). En dev local puede omitirse
# y se usa SQLite (sin búsqueda vectorial).
# DATABASE_URL=postgresql://user:pass@host:5432/vexconsulting

# --- Superadmin: SOLO se crea acá, nunca en la aplicación ---
SUPERADMIN_EMAIL=admin@vexconsulting.com.py
SUPERADMIN_NAME=Administrador VEX
SUPERADMIN_PASSWORD=CambiarEstaPassword123!
# Alternativa segura: hash bcrypt (dejar SUPERADMIN_PASSWORD vacío)
# SUPERADMIN_PASSWORD_HASH=$2b$12$...

JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=40

# --- OpenAI (agentes + embeddings) ---
OPENAI_API_KEY=
AGENT_MODEL=gpt-5.4
AGENT_REASONING_EFFORT=medium
EMBEDDING_MODEL=text-embedding-3-small

# --- Perplexity (investigación profunda, opcional) ---
PERPLEXITY_API_KEY=

# OCR para PDFs escaneados (requiere tesseract en la imagen)
OCR_ENABLED=false

CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=INFO

